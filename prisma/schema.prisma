generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum RecurrencePattern {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  WEEKDAYS
}

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lists     TaskList[]
  tasks     Task[]
}

model TaskList {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  color     String?
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  tasks     Task[]

  @@index([userId])
}

model Task {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  isCompleted Boolean   @default(false)
  isStarred   Boolean   @default(false)
  isMyDay     Boolean   @default(false)
  dueDate     DateTime?
  reminderAt  DateTime?
  completedAt DateTime?
  recurrencePattern  RecurrencePattern @default(NONE)
  recurrenceInterval Int               @default(1)
  recurrenceDays     String[]
  recurringSourceId  String?           @db.ObjectId
  listId      String    @db.ObjectId
  userId      String    @db.ObjectId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  list        TaskList  @relation(fields: [listId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  subtasks    Subtask[]

  @@index([userId, listId])
  @@index([userId, isCompleted])
  @@index([userId, isStarred])
  @@index([userId, isMyDay])
  @@index([userId, dueDate])
}

model Subtask {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  isCompleted Boolean  @default(false)
  taskId      String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id])

  @@index([taskId])
}
